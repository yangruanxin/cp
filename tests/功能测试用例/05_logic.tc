int main() {
    int a = 0;
    int b = 1;
    // short-circuit: a != 0 is false, so right side (which would
    // divide by zero) should never be evaluated
    int x = a && (10 / a);
    // short-circuit: b != 0 is true, so right side not evaluated
    int y = b || (10 / b);
    if (x == 0 && y == 1) {
        return 1;
    }
    return 0;
}
